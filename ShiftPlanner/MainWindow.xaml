<Window x:Class="ShiftPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShiftPlanner"
        Closing="SoftwareClosing"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Schichtplaner" Height="500" Width="900">

    <Window.Resources>

        <!-- Theme colours -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#17181B"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#222428"/>
        <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#303238"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#454850"/>

        <SolidColorBrush x:Key="TextBrush" Color="White"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9B9CA3"/>

        <SolidColorBrush x:Key="AccentBrush" Color="#4F8CFF"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#6CA0FF"/>
        <local:DivideBySevenConverter x:Key="DivideBySevenConverter"/>
        <Style x:Key="TransparentButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                    Background="Transparent"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- General modern button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">

                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder"
                                    Property="Background"
                                    Value="{StaticResource SurfaceHoverBrush}"/>

                                <Setter TargetName="ButtonBorder"
                                    Property="BorderBrush"
                                    Value="{StaticResource AccentBrush}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder"
                                    Property="Opacity"
                                    Value="0.75"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder"
                                    Property="Opacity"
                                    Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton"
       TargetType="Button"
       BasedOn="{StaticResource ModernButton}">

            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <!-- Primary action button -->
        <Style x:Key="AccentButton"
           TargetType="Button"
           BasedOn="{StaticResource ModernButton}">

            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"
                        Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

   
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0"
               Padding="5,0,0,0"
              Background="#1E1E1E"
               VerticalAlignment="Top">
            
            <Border  Background="Transparent" Height="35"
                     VerticalAlignment="Top">
                <Menu Background="#1E1E1E" 
                      Foreground="White" VerticalAlignment="Top" BorderThickness="0">

                    <MenuItem x:Name="SaveButton" Header="Datei" Background="#2D2D30" FontSize="14" BorderThickness="10" BorderBrush="LightGray" Width="auto" HorizontalAlignment="Left" VerticalAlignment="Top" HorizontalContentAlignment="Center" >
                        <MenuItem Header="Speicher" Command="Save" Background="#1E1E1E"   Foreground="White"/>
                        <MenuItem Header="Speichern unter" Click="Click_SavePlan" Background="#1E1E1E"   Foreground="White"/>
                        <MenuItem Header="Laden" Click="Click_LoadPlan" Background="#1E1E1E"   Foreground="White"/>
                        <Separator/>
                        <MenuItem Header="Export_CSV" Click="Click_ExportCSV" Background="#1E1E1E"   Foreground="White"/>
                        <MenuItem Header="Export_PDF" Click="Click_ExportPDF_DayMA" Background="#1E1E1E"   Foreground="White"/>
                        <MenuItem Header="Export_PDF_Pro_Mitarbeiter" Click="Click_ExportPDFPerPerson" Background="#1E1E1E"   Foreground="White"/>
                    </MenuItem>

                    <MenuItem FontSize="14"   Header="Standorte" Background="#2D2D30" BorderThickness="0,0,1,1" BorderBrush="LightGray" Width="auto" HorizontalAlignment="Left" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" >
                        <MenuItem Header="Neuer Standort"  Click="AddStandort_Click" Background="#1E1E1E"   Foreground="White" />
                        <MenuItem Header="Standort löschen" Background="#1E1E1E"   Foreground="White"  Click="RemoveStandort_Click"/>
                        <MenuItem Header="Standortschichten löschen" Background="#1E1E1E"   Foreground="White"  Click="StandortSchichtenLoeschen_Click"/>
                    </MenuItem>

                    <MenuItem FontSize="14"  Header="Mitarbeiter" Background="#2D2D30"  BorderBrush="LightGray" BorderThickness="0,0,1,1" Width="auto" HorizontalAlignment="Left" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" >
                        <MenuItem Header="Neuer Mitarbeiter"  Click="AddEmployee_Click" Background="#1E1E1E"   Foreground="White"/>
                        <MenuItem Header="Mitarbeiter löschen"  Click="RemoveEmployee_Click" Background="#1E1E1E"   Foreground="White"/>
                        <Separator/>
                        <MenuItem Header="Rolle hinzufügen"  Click="AddRole_Click" Background="#1E1E1E"   Foreground="White"/>
                        <MenuItem Header="Rolle löschen"  Click="RemoveRole_Click" Background="#1E1E1E"   Foreground="White"/>
                        <MenuItem Header="Rolle umbenennen"  Click="RenameRole_Click" Background="#1E1E1E"   Foreground="White"/>
                    </MenuItem>

                    <MenuItem FontSize="14"  Header="Settings" Background="#2D2D30" BorderThickness="0,0,1,1" BorderBrush="LightGray" Width="auto" HorizontalAlignment="Left" VerticalAlignment="Stretch" HorizontalContentAlignment="Center">
                        <MenuItem   x:Name="FarbSettings"  Header="Farbe nur für Kanten" Height="20"
                                     IsCheckable="True" Checked="RedrawCalendar"  Unchecked="RedrawCalendar" Background="#1E1E1E"   Foreground="White">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <TextBlock Text="✓"
                                   Foreground="LimeGreen"
                                   FontWeight="Bold"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Icon" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem   x:Name="FarbExport"  Header="Nutze Farbe für PDF Export" Height="20"
                            IsCheckable="True" Checked="ChangeColorforPDF"  Unchecked="ChangeColorforPDF" Background="#1E1E1E"   Foreground="White">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <TextBlock Text="✓"
                                                 Foreground="LimeGreen"
                                                 FontWeight="Bold"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Icon" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <Separator/>
                        <MenuItem  x:Name="VerwendePausenzeiten"   Header="Berechne gesetzliche Pausenzeiten"
    IsCheckable="True" Checked="ChangePausenSettings"  Unchecked="ChangePausenSettings" Background="#1E1E1E"   Foreground="White" Height="20">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <TextBlock Text="✓"
      Foreground="LimeGreen"
      FontWeight="Bold"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Icon" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem   x:Name="WochenendToggle"  Header="Wochenenden ausblenden" Height="20"
                                IsCheckable="True" Checked="ChangeWEVisibility"  Unchecked="ChangeWEVisibility" Background="#1E1E1E"   Foreground="White">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <TextBlock Text="✓"
                                        Foreground="LimeGreen"
                                        FontWeight="Bold"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Icon" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem   x:Name="Kuerzelsettings"  Header="Rollen Kürzel verwenden" Height="20"
                  IsCheckable="True" Checked="ChangeKZOn_Click"  Unchecked="ChangeKZOn_Click" Background="#1E1E1E"   Foreground="White">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <TextBlock Text="✓"
                                                Foreground="LimeGreen"
                                                FontWeight="Bold"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Icon" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem  x:Name="KuerzelsettingsST"   Header="Standort Kürzel verwenden" Height="20"
    IsCheckable="True" Checked="ChangeSTKZOn_Click"  Unchecked="ChangeSTKZOn_Click" Background="#1E1E1E"   Foreground="White">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <TextBlock Text="✓"
                                  Foreground="LimeGreen"
                                  FontWeight="Bold"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Icon" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <Separator/>
                        <MenuItem  x:Name="ZeigeAbwesenheitsGrund"   Header="Export Abwesenheitsgrund" Height="20"
                                IsCheckable="True" Checked="ChangeAbwesenheitsSettings"  Unchecked="ChangeAbwesenheitsSettings" Background="#1E1E1E"   Foreground="White">
                            <MenuItem.Style>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Icon">
                                        <Setter.Value>
                                            <TextBlock Text="✓"
                                           Foreground="LimeGreen"
                                           FontWeight="Bold"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="False">
                                            <Setter Property="Icon" Value="{x:Null}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </MenuItem.Style>
                        </MenuItem>
                        <MenuItem Header="Export Fontgröße Standort"  Background="#1E1E1E"   Foreground="White">
                            <MenuItem x:Name="ExportFont" Header="Aktuelle Größe: 12" Background="#1E1E1E"   Foreground="White" Click="ChangeFontSize_Click" />
                        </MenuItem>
                        <MenuItem Header="Export Fontgröße Mitarbeiter"  Background="#1E1E1E"   Foreground="White">
                            <MenuItem x:Name="ExportFontMA" Header="Aktuelle Größe: 12"  Background="#1E1E1E"   Foreground="White" Click="ChangeFontSizeMA_Click" />
                        </MenuItem>
                    </MenuItem>

                    <MenuItem FontSize="14"  Header="Tools" Background="#2D2D30"  BorderBrush="LightGray" BorderThickness="0,0,1,1" Width="auto" HorizontalAlignment="Left" VerticalAlignment="Stretch" HorizontalContentAlignment="Center" >
                        <MenuItem Header="Verteile automatisiert Schichten"  Click="OpenAutomator" Background="#1E1E1E"   Foreground="White"/>
                    </MenuItem>

                </Menu>
            </Border>
        </Border>

        <Grid Grid.Row="1" Grid.ColumnSpan="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"  MaxWidth="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto" MaxWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Border Grid.Column="0" x:Name="LeftBorder"
            Background="#2D2D30"
            Padding="5,0,5,5" Width="250" Visibility="Visible">

                <TabControl x:Name="PlanTabs"
                        Background="#2D2D30" BorderThickness="0">

                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Margin" Value="2,0,2,0"/>
                        </Style>
                    </TabControl.Resources>


                    <TabItem Header="Standorte" Width="70">
                        <Grid Margin="0,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0"
                              Margin="0,15,0,0"
                              VerticalScrollBarVisibility="Auto">
                             

                                <StackPanel x:Name="StandortBox"
                                Width="210"
                                HorizontalAlignment="Center">
                                    <!-- Employees are filled in runtime-->
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Mitarbeiter"
                         Padding="0"
                         Width="70">
                        <Grid Margin="0,0,0,0">

                            <Grid.RowDefinitions>
                                <RowDefinition Height="5"/>
                                <RowDefinition Height="20"/>
                                <RowDefinition Height="25"/>
                                <RowDefinition Height="27"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>



                            <Grid Grid.Row="2"
                            Margin="0,5,0,0" >

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="25"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Nur Mitarbeiter im Standort anzeigen:"
                                       Foreground="White"  />
                                <CheckBox x:Name="MAHaken"  Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Checked="FilterMAbyStandort" Unchecked="FilterMAbyStandort"/>
                            </Grid>

                            <TextBlock Grid.Row="1" Text="Sortieren:" FontStyle="Normal" FontSize="16" FontWeight="Bold" Foreground="White"></TextBlock>

                            <Grid Grid.Row="3"
                                >

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="Sortierungen"
                                Grid.Column="0"
                                 Width="140"
                                          Height="25"
                                  Margin="0,0,0,0"
                                 SelectedItem="Name"
                                 HorizontalAlignment="Left"
                                          VerticalAlignment="Top"
                                 HorizontalContentAlignment="Left"
                                 SelectionChanged="ReloadSort"
                                 />

                                <Button  x:Name="Orientierung" Padding="0,-3,0,0"  Grid.Column="1" Width="20" Height="20" Content="↓" FontSize="20" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="ChangeOrder"    />
                                <Button   Grid.Column="2" Padding="0,0,0,0" Width="20" Height="20" Content="↻" FontSize="15" HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="ReloadSort"    />

                            </Grid >

                            <ScrollViewer Grid.Row="5"
                              Margin="0,15,0,0"
                              VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="EmployeeBox"
                                Width="210"
                                HorizontalAlignment="Center">
                                    <!-- Employees are filled in runtime-->
                                </StackPanel>
                            </ScrollViewer>



                        </Grid>
                    </TabItem>






                </TabControl>



            </Border>

            <!-- CENTER calendar -->
            <Border Grid.Column="1"
            Background="#1E1E1E"
            Padding="0">


                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>


                    <Border x:Name="WorkBorder" BorderThickness="0,0,0,2" BorderBrush="LightGray" Grid.Row="0" HorizontalAlignment="Stretch">
                        <Grid 
                                    HorizontalAlignment="Stretch">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition MinWidth="60" Width="*" MaxWidth="250"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="25"/>
                            </Grid.ColumnDefinitions>

                            <Border  Grid.Column="0" VerticalAlignment="Top"  x:Name="LeftClapBorder"
                             Background="#2D2D30"  BorderThickness="0,0,2,0" CornerRadius="0,5,5,0"
                              BorderBrush="LightGray" >

                                <Button x:Name="LeftRowB" Content="&lt;"
                                  Width="20"
                                  Height="45"
                                        FontWeight="Bold"
                                        Style="{StaticResource TransparentButton}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                  HorizontalContentAlignment="Center"
                                   FontSize="16"
                                    Foreground="White"
                                    Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0,0,0,0" 
                                  Click="ClapInLeft" >

                                </Button>

                            </Border>

                            <TextBlock x:Name="LocationText"
                                 Grid.Column="1"
                                 Text=""
                                 FontSize="24"
                                 Foreground="White"
                                Margin="10,0"
                                VerticalAlignment="Center"
                                TextAlignment="Center"/>

                           
                            <Button Grid.Column="2" Content="&lt;"
                                   Width="20"
                                   Height="27"
                                      FontSize="16"
                                    Padding="0,0,0,2"
                                    Background="#2D2D30"
                                     Foreground="White"
                                    BorderBrush="LightGray"
                                    BorderThickness="2"
                                   Click="PreviousMonth_Click"/>
                            
                            
                            <TextBlock Grid.Column="3" x:Name="MonthTitleText"
                              Text="Month Year"
                              FontSize="24"
                              Foreground="White"
                             Margin="10,0"
                             VerticalAlignment="Center"/>
                            <Button Grid.Column="4" Content="&gt;"
                                      Width="20"
                                      FontSize="16"
                                      Padding="0,0,0,5"
                                      Height="27"
                                   Background="#2D2D30"
                                    Foreground="White"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Top"
                                       BorderBrush="LightGray"
                                        BorderThickness="2"
                                      Click="NextMonth_Click"/>

                            <Button Grid.Column="5" Content="Monat" FontSize="12"
                                 Click="Calendar_Click" Foreground="White">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                CornerRadius="8,0,0,0"
                                                Background="#2D2D30"
                                                BorderBrush="LightGray"
                                                          BorderThickness="2,2,0,0"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom">

                                            <ContentPresenter
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                    Margin="10"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="Black"/>
                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="Black"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="6" Content="Woche" FontSize="12"
                                        Click="WeekView_Click" Foreground="White">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                            CornerRadius="0,8,0,0"
                                            Background="#2D2D30"
                                            BorderBrush="LightGray"
                                            BorderThickness="1,2,2,0"
                                                 VerticalAlignment="Bottom"
                                                HorizontalAlignment="Left">

                                            <ContentPresenter
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                                Margin="10"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="Black"/>
                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="Black"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Border  Grid.Column="7" VerticalAlignment="Top"  x:Name="RightClapBorder"
                                  Background="#2D2D30"  BorderThickness="2,0,0,0" CornerRadius="5,0,0,5"
                                   BorderBrush="LightGray">

                                <Button Content="&gt;"
                                      x:Name="RightRowB"
                                      FontSize="16"
                                        FontWeight="Bold"
                                     HorizontalContentAlignment="Center"
                                     Foreground="White"
                                     Background="Transparent"
                                    BorderThickness="0,0,0,0"
                                     Style="{StaticResource TransparentButton}"
                                       Width="20"
                                       Height="45"
                                      
                               Click="ClapInRight"/>

                            </Border>
                          

                        </Grid>

                    </Border>


                    <Border Grid.Row="1" Visibility="Visible" x:Name="CalendarBorder">

                        <Grid Margin="5,0,5,5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Mo" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Di" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="Mi" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Do" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="Fr" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="5" Text="Sa" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="6" Text="So" FontSize="16" Foreground="White" HorizontalAlignment="Center"/>
                            </Grid>

                            <ItemsControl x:Name="DayController" Grid.Row="1" ItemsSource="{Binding _KalenderTage}">

                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid   Columns="7"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                            </ItemsControl>

                        </Grid>
                    </Border>


                    <ListBox x:Name="WeekDayList"
                             Grid.Row="1"
                              SelectionMode="Single"
                              Background="Transparent"
                             ItemsSource="{Binding _WochenTage}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch"
                             Visibility="Collapsed"
                             Margin="0,0,0,0"
                             Padding="0,0,0,2">

                        <ListBox.Resources>

                            <Style TargetType="Thumb">
                                <Setter Property="Background" Value="Red"/>
                            </Style>

                        </ListBox.Resources>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="MinHeight"
                                            Value="{Binding ActualHeight,
                                                            RelativeSource={RelativeSource AncestorType=ListBox},
                                                            Converter={StaticResource DivideBySevenConverter}}"/>
                                <Setter Property="Height" Value="auto"></Setter>
                                <Setter Property="Focusable" Value="False"/>

                                <Setter Property="Background" Value="Transparent"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="HoverBorder"
                                                         Background="Transparent">
                                                <ContentPresenter
                                                             HorizontalAlignment="Stretch"
                                                             VerticalAlignment="Stretch"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="HoverBorder"
                                                                  Property="Background"
                                                                  Value="#2A2A2A"/>
                                                </Trigger>

                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="HoverBorder"
                                                                 Property="Background"
                                                                 Value="#303030"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                        </ListBox.ItemContainerStyle>

                    </ListBox>

                </Grid>

            </Border>

            <!-- Richt Templates -->


            <Border Grid.Column="2" x:Name="RightBorder" Width="175"
            Background="#2D2D30"
            Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                        <RowDefinition Height="auto"></RowDefinition>
                    </Grid.RowDefinitions>


                    <StackPanel Grid.Row="0">

                        <TextBlock Text="Schichtdetails"
                            FontSize="24"
                            Foreground="White"
                            Margin="0,0,0,10"/>

                        <TextBlock Text="Rollenbezeichnung:"
                            FontSize="16"
                            Foreground="White"
            
                            Margin="0,0,0,5"/>      

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="50"></RowDefinition>
                                <RowDefinition Height="auto"></RowDefinition>
                            </Grid.RowDefinitions>

                            <ScrollViewer VerticalScrollBarVisibility="Auto" Grid.Row="0" VerticalAlignment="Stretch">

                                <ItemsControl x:Name="RoleController"  ItemsSource="{Binding _Rollen}"  VerticalAlignment="Stretch">

                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel 
                              Background="Transparent"
                              Margin="10,0,10,0" VerticalAlignment="Stretch" >
                                            </StackPanel>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Row="1">

                                <TextBlock Text="Schichtdauer:"
                                  FontSize="16"
                                  Foreground="White"
                                  Margin="0,10,0,5"/>


                                <Grid Margin="0,0,0,0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                        x:Name="Begin_Box"
                                        Text="08:00"
                                        FontSize="16"
                                        Width="50"
                                        Background="#293133"
                                        Foreground="White">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="LightGray"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <TextBlock Grid.Column="1"
                                         Text="-"
                                         FontSize="16"
                                         Foreground="White"
                                         Margin="0,0,0,0"
                                         HorizontalAlignment="Center"/>


                                    <TextBox Grid.Column="2"
                                        x:Name="Ende_Box"
                                        Text="16:30"
                                        FontSize="16"
                                        Width="50"
                                        Background="#293133"
                                        Foreground="White">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="BorderBrush" Value="LightGray"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter Property="BorderBrush" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                </Grid>



                                <TextBlock Text="Notiz:"
                                  FontSize="16"
                                  Foreground="White"
                                  Margin="0,10,0,5"/>

                                <TextBox x:Name="Notiz_Box"
                                   Text=""
                                   MinHeight="50"
                                   MaxHeight="300"
                                   FontSize="16"
                                   AcceptsReturn="True"
                                   TextWrapping="Wrap"
                                   Background="#293133"
                                   Foreground="White"
                                   CaretBrush="White"
                                   Margin="10,0,10,0"
                                        
                                    >
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="BorderBrush" Value="LightGray"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>


                            </StackPanel>
                        </Grid>

                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Version: 1.1.1 - alpha"
                      FontSize="12"
                      Foreground="Gray"
                      VerticalAlignment="Bottom"
                      Margin="0,0,0,0"/>


                </Grid>
              
            </Border>


        </Grid>

    </Grid>

</Window>
