<Window x:Class="ShiftPlanner.Subwidgets.EmployeeCreater"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Mitarbeitererstellung" Height="300" Width="400">
    <Grid>

        <StackPanel Margin="20">

            <TextBlock Text="Name"/>
            <TextBox x:Name="NameInput"
                 Text="Max Mustermann"
                 Margin="0,5,0,10"/>

            <TextBlock Text="Zielstunden:"/>
            <TextBox x:Name="HoursInput"
                 Text="160"
                 Margin="0,5,0,10"/>

            <TextBlock Text="Standorte:"/>
            <ScrollViewer 
                Margin="0,5,0,10"
                MaxHeight="150"
                VerticalScrollBarVisibility="Auto" >
                <ListBox x:Name="Locations"
                    SelectionMode="Multiple"
                    Margin="0,0,0,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Style.Triggers>

                                <Trigger Property="IsSelected"
                         Value="True">
                        
                                    <Setter Property="Foreground"
                            Value="DeepSkyBlue"/>
                                </Trigger>

                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

            </ScrollViewer>
           
            <Grid Margin="0,0,0,0"
                  HorizontalAlignment="Center">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                    Content="Add"
                    Width="80"
                    Margin="0,0,50,0"
                    HorizontalAlignment="Left"
                    Click="Add_Click"/>

                <Button Grid.Column="1"
                    Content="cancel"
                    Width="80"
                    HorizontalAlignment="Right"
                    Click="Cancel_Click"/>

            </Grid>

        </StackPanel>
    </Grid>
</Window>
