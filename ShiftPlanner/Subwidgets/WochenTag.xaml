<UserControl x:Class="ShiftPlanner.Subwidgets.WochenTag"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
        <Border x:Name="RootBorder"
            BorderBrush="Gray"
            BorderThickness="1"
            Background="Transparent"
            Margin="2"
            HorizontalAlignment="Stretch"
            Padding="10"
            MouseLeftButtonDown="CellClick"
            CornerRadius="5">

            <Grid >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto" MinWidth="35"/>
                    <ColumnDefinition MinWidth="55" Width="auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>


                    <TextBlock  Grid.Row="0" x:Name="TagesText" TextWrapping="Wrap" Foreground="White" Text="Mo" FontSize="20" Padding="0,0,0,0" FontWeight="Bold" HorizontalAlignment="Left" VerticalAlignment="Top">
                    </TextBlock>
                    <TextBlock x:Name="DateText" Text="30" Foreground="White" Margin="5,5,0,0" FontSize="16" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                 
                 </Grid>

                <Grid Grid.Column="1">

                    <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="23"/>
                        
                    </Grid.RowDefinitions>

                <TextBlock x:Name="KalenderWoche" FontSize="16" Padding="0,0,0,0" FontWeight="DemiBold" Foreground="White" Margin="5,5,0,0" Grid.Row="0" VerticalAlignment="Bottom" 
                    TextAlignment="Left" Text="KW 24" TextWrapping="Wrap" Visibility="Collapsed"/>


                <TextBlock x:Name="HolidayText" Foreground="Violet"  Text="Fronleichnam" Visibility="Collapsed"  FontSize="11" Margin="0,5,5,0" Grid.Row="1" VerticalAlignment="Bottom" 
                               TextAlignment="Left"  TextWrapping="Wrap"/>

           

                </Grid>



                <WrapPanel x:Name="ContentBox"
                             Orientation="Horizontal"  Grid.Column="2">
                    <WrapPanel.Resources>
                        <Style TargetType="local:SchichtLabel">
                            <Setter Property="Margin" Value="5,2,5,2"/>
                        </Style>
                    </WrapPanel.Resources>
                </WrapPanel>
        </Grid>
      
        </Border>
    
</UserControl>
