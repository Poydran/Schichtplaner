<UserControl x:Class="ShiftPlanner.Subwidgets.Employee"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="230">
    <Border x:Name="RootBorder"
            Background="#3A3A3A"
            CornerRadius="6"
            BorderThickness="2"
            Padding="5"
            Margin="0,0,0,8"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown"
            MouseRightButtonDown="RootBorder_MouseRightButtonDown">

        <StackPanel>
            <TextBlock x:Name="NameText"
                       Text="Employee"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"/>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"/>
                    <ColumnDefinition MaxWidth="45"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                    x:Name="VerplanteStunden"
                   Text="0"
                   Foreground="LightGray"
                   FontSize="12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"/>
                
                <TextBlock Grid.Column="1"
                    x:Name="MaxStunden"
                   Text=" / 160 h"
                   Foreground="LightGray"
                   FontSize="12"
                   VerticalAlignment="Bottom"/>
             
                
            </Grid>
            <TextBlock 
                x:Name="Rollen"
                Text="Rollen: Kasse, Aufsicht"
                Foreground="LightGray"
                FontSize="12"
                />
            <TextBlock 
                Text="Rechtsklick für mehr Information"
                Foreground="Gray"
                FontSize="10"
                Margin="5,0,0,5"/>


        </StackPanel>

    </Border>
</UserControl>
