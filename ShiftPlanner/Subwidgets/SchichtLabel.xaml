<UserControl x:Class="ShiftPlanner.Subwidgets.SchichtLabel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
             mc:Ignorable="d" 
             d:DesignHeight="75" d:DesignWidth="300">

    <UserControl.Resources>
        <local:ContrastForegroundConverter
        x:Key="ContrastForegroundConverter"/>
    </UserControl.Resources>
    <Border x:Name="RootBorder"
        Background="#3A3A3A"
        CornerRadius="6"
        Padding="5"
        Margin="0,0,0,8"
        BorderThickness="2"
        MouseRightButtonDown="EditSchicht"
        MinWidth="110">

        <StackPanel>
            <TextBlock x:Name="NameText"
                   Text="Employee"
         
                   FontSize="16"
                   FontWeight="Bold"
                 
  Foreground="{Binding ElementName=RootBorder,
                                    Path=Background,
                       Converter={StaticResource ContrastForegroundConverter}}"/>

            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                    x:Name="StartZeit"
                   Text="08:00"
            
                   FontSize="12"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"                          Foreground="{Binding ElementName=RootBorder,
                                    Path=Background,Converter={StaticResource ContrastForegroundConverter}}"/>


                <TextBlock Grid.Column="2"
               Text=" bis"
           
               FontSize="12"
               VerticalAlignment="Bottom"                               
Foreground="{Binding ElementName=RootBorder,
                                    Path=Background, Converter={StaticResource ContrastForegroundConverter}}"/>

                <TextBlock Grid.Column="3"
                     x:Name="SchlussZeit"
                    Text="16:00"
             
                    FontSize="12"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"                                
Foreground="{Binding ElementName=RootBorder,
                                    Path=Background, Converter={StaticResource ContrastForegroundConverter}}"/>

                <TextBlock Grid.Column="4"
                   Text="Uhr"
              
                   FontSize="12"
                   HorizontalAlignment="Left"
                           Margin="2,0,0,0"
                   VerticalAlignment="Bottom"                          
Foreground="{Binding ElementName=RootBorder,
                                    Path=Background,  Converter={StaticResource ContrastForegroundConverter}}"/>
                <TextBlock Grid.Column="5"
                    x:Name="PlusDayText"
                    Text="+1"
               
                    FontSize="12"
                    HorizontalAlignment="Center"
                            Margin="0,0,0,0"
                           Visibility="Collapsed"
                    VerticalAlignment="Bottom"                                
Foreground="{Binding ElementName=RootBorder,
                                    Path=Background, Converter={StaticResource ContrastForegroundConverter}}"/>
                <TextBlock Grid.Column="6"
                    x:Name="AlsText"
                    Text="als"
               
                    FontSize="12"
                    HorizontalAlignment="Center"
                            Margin="0,0,0,0"
                           Visibility="visible"
                    VerticalAlignment="Bottom"                                
Foreground="{Binding ElementName=RootBorder,
                                    Path=Background, Converter={StaticResource ContrastForegroundConverter}}"/>

                <TextBlock Grid.Column="7"
                     x:Name="RollenText"
                            Visibility="visible"
                    Text="Schichtleiter"
                   
                    FontSize="12"
                    HorizontalAlignment="Left"
                            Margin="5,0,0,0"
                    VerticalAlignment="Bottom"                               
Foreground="{Binding ElementName=RootBorder,
                                    Path=Background, Converter={StaticResource ContrastForegroundConverter}}"/>


            </Grid>
        </StackPanel>

    </Border>
</UserControl>
