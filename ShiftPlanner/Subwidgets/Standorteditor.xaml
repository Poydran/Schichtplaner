<Window x:Class="ShiftPlanner.Subwidgets.Standorteditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
        xmlns:main="clr-namespace:ShiftPlanner"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Standortinfo" Height="450" Width="800">

    <Window.Resources>
        <main:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>
    </Window.Resources>

    <Border x:Name="RootBorder"
     Background="#2D2D30"
     Padding="10"
     Margin="0,0,0,8">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                    Text="Standortinfo:"
                    Foreground="White"
                    FontSize="20"
                    VerticalAlignment="Center"
                    FontWeight="Bold"/>

                <Button Grid.Column="1"
                    x:Name="DeleteButton"
                    Content="Alle Schichten Löschen"
                    Width="auto"
                    Height="30"
                    Margin="0,5,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="ClearAllShifts"
                    Visibility="Collapsed"/>

                <Button Grid.Column="2"
                     x:Name="EditButton"
                     Content="Bearbeiten"
                     Width="100"
                     Height="30"
                     Margin="0,5,0,0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Click="StartEdit"
                     Visibility="Visible"/>

                <Button Grid.Column="2"
                     x:Name="SpeicherButton"
                     Content="Speichern"
                     Width="100"
                     Height="30"
                     Margin="0,5,0,0"
                     VerticalAlignment="Top"
                     HorizontalAlignment="Right"
                     Click="SaveEdit"
                     Visibility="Collapsed"/>

            </Grid>
            <StackPanel Margin="10,5,0,0">
                
                <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>


                <TextBlock
                Grid.Column="0"
                  Text="Name:"
                  Foreground="White"
                  FontSize="16"
                  />

                <TextBlock
                    Grid.Column="1"
                  x:Name="StandortName"
                  Text="Dokuzentrum"
                  Foreground="White"
                  FontSize="16"
                    Visibility="Visible"
               
                />

                <TextBox
                  Grid.Column="1"
                MinWidth="50"
                HorizontalAlignment="Left"
                x:Name="StandortNameEdit"
                Text="Name:"
                CaretBrush="White"
                Foreground="White"
                BorderBrush="LightGray"
                FontSize="16"
                Visibility="Collapsed"
                 Background="Transparent"
                />


            </Grid>

            <Grid Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>


                <TextBlock
             Grid.Column="0"
               Text="Kürzel:"
               Foreground="White"
               FontSize="16"
               />

                <TextBlock
                 Grid.Column="1"
               x:Name="StandortKuerzel"
               Text=""
               Foreground="White"
               FontSize="16"
                 Visibility="Visible"
    
             />

                <TextBox
               Grid.Column="1"
             MinWidth="50"
             HorizontalAlignment="Left"
             x:Name="StandortKuerzelEdit"
             Text="Name:"
             CaretBrush="White"
             Foreground="White"
             BorderBrush="LightGray"
             FontSize="16"
             Visibility="Collapsed"
              Background="Transparent"
             />


            </Grid>

            <Grid Margin="0,10,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="50"/>
                </Grid.ColumnDefinitions>


                <TextBlock
                  Grid.Column="0"
                    Text="Bundesland:"
                    Foreground="White"
                    FontSize="16"
                    />

                <TextBlock
                    Grid.Column="1"
                    x:Name="BundeslandText"
                    Text="{Binding Bundesland,
                          Converter={StaticResource EnumDescriptionConverter}}" 
                    Foreground="White"
                    FontSize="16"
                      Visibility="Visible" Grid.ColumnSpan="2" Margin="0,0,10,0"
    
                  />

                <ComboBox x:Name="BundeslaenderWahl"
                  Grid.Column="1"
                   Width="100"
                    Margin="0,0,0,0"
                   SelectedItem=""
                   HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                   HorizontalContentAlignment="Left"
                   Visibility="Collapsed"
                   >

                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock
                   Grid.Column="2"
                     Text="An Feiertagen geschlossen:"
                     Foreground="White"
                     FontSize="16"
                     />

                <CheckBox
                   Grid.Column="3"
                   x:Name="CBClosedOnHoliday"
                   Foreground="White"
                   FontSize="16"
                   IsHitTestVisible="False"
                   />


            </Grid>

            <StackPanel>

                <Grid Margin="0,10,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox
                     Grid.Column="1"
                   MinWidth="50"
                    CaretBrush="White"
                   HorizontalAlignment="Left"
                   x:Name="RoleEdit"
                   Text="Name:"
                   Foreground="White"
                   BorderBrush="LightGray"
                   FontSize="16"
                   Visibility="Collapsed"
                    Background="Transparent"
                   />


                </Grid>


                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="150"/>
                        <ColumnDefinition  Width="auto"/>
                        <ColumnDefinition  Width="30"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                         Grid.Column="0"
                         Text="Geschlossene Tage: "
                         Foreground="White"
                         FontSize="16"
                    />

                    <TextBlock
                        Grid.Column="1"
                        x:Name="Schliesstage"
                        Text=""
                        Foreground="White"
                        FontSize="16"
                        Visibility="Visible"
                    />

                    <TextBox
                       Grid.Column="1"
                       x:Name="SchliesstagBox"
                       Text="Sa,So,10-14,31"
                       FontSize="16"
                        MinWidth="50"
                        CaretBrush="White"
                       Margin="0,0,50,0"
                       Foreground="White"
                     BorderBrush="LightGray"
                     Visibility="Collapsed"
                        HorizontalAlignment="Left"
                      Background="Transparent"
                    />

                    <Border Width="18" Grid.Column="2" x:Name="SchliessTooltip"
                       Height="18"
                       CornerRadius="9" HorizontalAlignment="Left"
                       Background="#3A3A3A" Margin="5,0,0,0"
                       Visibility="Collapsed"
                       Cursor="Help" VerticalAlignment="Center">
                        <Border.ToolTip>
                            <ToolTip FontSize="16">
                                <TextBlock TextWrapping="Wrap">
                                    Wochentage:     Mo,Di,Mi...
                                    <LineBreak/>
                                    Einzeltage:     1,10,15,20...
                                    <LineBreak/>
                                    Zeitspannen:    5-15,18-21...
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>

                        <TextBlock Text="i"
      Foreground="Yellow"
      FontWeight="Bold"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </StackPanel>
            
                
            </StackPanel>
            
            
        </StackPanel>
    </Border>
</Window>
