<Window x:Class="ShiftPlanner.Subwidgets.SchichtEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Schichtinfo" Height="450" Width="800">
    <Border x:Name="RootBorder"
         Background="#3A3A3A"
        
         Padding="10"
         Margin="0,0,0,8">

        <StackPanel>
            <Grid >

                <Grid.ColumnDefinitions>
                    <ColumnDefinition  Width="150"/>
                    <ColumnDefinition  Width="*"/>
                    <ColumnDefinition  Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                        Text="SchichtDetails:"
                        Foreground="White"
                        FontSize="16"
                        FontWeight="Bold"/>

                <Button Grid.Column="1"
                        x:Name="DeleteButton"
                Content="Schicht entfernen"
                Width="120"
                Height="30"
                Margin="0,0,15,0"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                Click="DeleteSchicht"/>
                
                <Button Grid.Column="2"
                    x:Name="EditButton"
                    Content="Bearbeiten"
                    Width="100"
                    Height="30"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="StartEdit"
                    Visibility="Visible"/>

                <Button Grid.Column="2"
                    x:Name="SaveButton"
                    Content="Speichern"
                    Width="100"
                    Height="30"
                    Margin="0,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Click="SaveEdit"
                    Visibility="Collapsed"/>

            </Grid>
            <StackPanel>

                <TextBlock
                  x:Name="SchichtDatum"
                  Text="Datum:"
                  Foreground="White"
                  FontSize="16"
                  />

                <TextBlock
                    x:Name="SchichtStandort"
                    Text="Standort:"
                    Foreground="White"
                    FontSize="16"
                    Margin="0,10,0,0"
                    />


                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="300"/>
                        <ColumnDefinition  Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        x:Name="MitarbeiterText"
                        Text="Mitarbeiter: "
                        Foreground="White"
                         Margin="0,10,0,0"
                        FontSize="16"
                        />

                    <TextBlock Grid.Column="1"
                      x:Name="MitarbeiterRolleText"
                      Text="Mitarbeiterrolle: "
                      Foreground="White"
                       Margin="0,10,0,0"
                      FontSize="16"
                      />

                </Grid>

               
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="75"/>
                        <ColumnDefinition Width="0"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="0"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="45"/>
                        <ColumnDefinition Width="115"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                         Text="Zeitraum: "
                         Foreground="White"
                         FontSize="16"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Bottom"/>

                    <TextBlock Grid.Column="2"
                         x:Name="StartZeit"
                        Text="08:00"
                        Foreground="White"
                        FontSize="12"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"/>

                    <TextBox
                        Grid.Column="2"
                        x:Name="StartZeitBox"
                        Text="08:00"
                        FontSize="12"
                        CaretBrush="White"
                        Foreground="White"
                        BorderBrush="LightGray"
                        Visibility="Collapsed"
                         HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                       Background="Transparent"
                        />



                    <TextBlock Grid.Column="4"
                        Text=" bis"
                        Foreground="White"
                        FontSize="12"
                        VerticalAlignment="Bottom"/>

                    <TextBlock Grid.Column="5"
                          x:Name="SchlussZeit"
                         Text="16:00"
                         Foreground="White"
                         FontSize="12"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Bottom"/>

                    <TextBox
                        Grid.Column="5"
                        x:Name="SchlussZeitBox"
                        Text="16:00"
                        FontSize="12"
                         CaretBrush="White"
                        Foreground="White"
                        BorderBrush="LightGray"
                        Visibility="Collapsed"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                       Background="Transparent"
                        />

                    <TextBlock Grid.Column="6"
                        Text="Uhr"
                        Foreground="White"
                        FontSize="12"
                        HorizontalAlignment="Left"
                        Margin="2,0,0,0"
                        VerticalAlignment="Bottom"/>

                    <TextBlock Grid.Column="7"
                         Text="Dauer: "
                         Foreground="White"
                         FontSize="16"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Bottom"/>

                    <TextBlock Grid.Column="8"
                         x:Name="StundenZahl"
                         Text="8 std"
                         Foreground="White"
                         FontSize="12"
                         HorizontalAlignment="Left"
                         Margin="0,0,0,0"
                         VerticalAlignment="Bottom"/>

                    <TextBlock Grid.Column="9"
                      Text="ges. Pause: "
                      Foreground="White"
                      FontSize="16"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Bottom"/>

                    <TextBlock Grid.Column="10"
                            x:Name="Pausendauer"
                            Text="8 min"
                            Foreground="White"
                            FontSize="12"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,0"
                            VerticalAlignment="Bottom"/>
                </Grid>

                <TextBlock 
                   
                   
                    Text="Notiz:"
                    Foreground="White"
                    FontSize="16"
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0"
                    VerticalAlignment="Bottom"/>

                <TextBox 
                     x:Name="NoteBlock"
                     Text=""
                     TextWrapping="Wrap"
                     IsReadOnly="true"
                     Foreground="WhiteSmoke"
                     Background="Transparent"
                     BorderThickness="2"
                     Width="500"
                     Height="150"
                     BorderBrush="Gray"
                     FontSize="16"
                     HorizontalAlignment="Left"
                     Margin="20,5,0,0"
                     VerticalAlignment="Bottom"/>

            </StackPanel>

         

        </StackPanel>

    </Border>
</Window>
