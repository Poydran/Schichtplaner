<Window x:Class="ShiftPlanner.Subwidgets.StandortCreater"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Standorterstellung" Height="300" Width="400">
    <Grid>
        <StackPanel Margin="20">

            <TextBlock Text="Standortname:"/>
            <TextBox x:Name="NameInput"
         Text="Dokumentationszentrum"
         Margin="0,5,0,10"/>


            <Grid Margin="0,0,0,0"
          HorizontalAlignment="Center">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
            Content="Add"
            Width="80"
            Margin="0,0,50,0"
            HorizontalAlignment="Left"
            Click="Add_Click"/>

                <Button Grid.Column="1"
            Content="cancel"
            Width="80"
            HorizontalAlignment="Right"
            Click="Cancel_Click"/>

            </Grid>

        </StackPanel>
    </Grid>
</Window>
