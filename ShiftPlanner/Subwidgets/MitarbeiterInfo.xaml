<Window x:Class="ShiftPlanner.Subwidgets.MitarbeiterInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Mitarbeiterinfo" Height="800" Width="800">
    <Border x:Name="RootBorder"
     Background="#2D2D30"
    
     Padding="10"
     Margin="0,0,0,8">

        <StackPanel>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>


                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                Text="Mitarbeiterinfo:"
                Foreground="White"
                FontSize="20"
                VerticalAlignment="Center"
                FontWeight="Bold"/>

                <Button Grid.Column="1"
                     x:Name="DeleteShifts"
                     Content="Schichten löschen"
                     Width="120"
                     Height="30"
                     Margin="0,5,0,0"
                     HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                     Click="DeleteSchiftsEdit"
                     Visibility="Collapsed"/>

                <Button Grid.Column="1"
                   x:Name="ExportMAPDF"
                   Content="Exportiere PDF"
                   Width="120"
                   Height="30"
                   Margin="0,5,0,0"
                   HorizontalAlignment="Right"
                          VerticalAlignment="Top"
                   Click="ExportMA"
                   Visibility="Visible"/>


                <Button Grid.Column="2"
                 x:Name="EditButton"
                 Content="Bearbeiten"
                 Width="100"
                 Height="30"
                 Margin="0,5,0,0"
                 HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                 Click="StartEdit"
                 Visibility="Visible"/>

                <Button Grid.Column="2"
                 x:Name="SpeicherButton"
                 Content="Speichern"
                 Width="100"
                 Height="30"
                 Margin="0,5,0,0"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Right"
                 Click="SaveEdit"
                 Visibility="Collapsed"/>

            </Grid>

            <Grid Margin="10,5,0,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>

                </Grid.ColumnDefinitions>


                <TextBlock Height="30"
                    Grid.Column="0"
              Text="Name:"
              Foreground="White"
              FontSize="16"
              />

                <TextBlock
                    Grid.Column="1"
                  x:Name="MAName"
                  Text="Hans"
                    Height="30"
                  Foreground="White"
                  FontSize="16"
                    Visibility="Visible"
                   
                  />

                <TextBox
                      Grid.Column="1"
                    MinWidth="50"
                    Height="30"
                    HorizontalAlignment="Left"
                    x:Name="MANameEdit"
                    Text="Name:"
                    CaretBrush="White"
                    Foreground="White"
                    BorderBrush="LightGray"
                    FontSize="16"
                    Visibility="Collapsed"
                     Background="Transparent"
                    >
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="LightGray"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
                <mah:ColorPicker Grid.Column="2" x:Name="MyColorPicker" Height="30" Width="50" SelectedColor="#3A3A3A" IsEnabled="False" Margin="10,0,0,0"/>
                
                

            </Grid>
            <StackPanel Margin="10,0,0,0">
                     <Grid>

                         <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="100"/>
                        <ColumnDefinition  Width="*"/>
                        </Grid.ColumnDefinitions>


                        <TextBlock
                         Grid.Column="0"
                          Text="Standorte:"
                          TextAlignment="Justify"
                           
                          Foreground="White"
                          FontSize="16"
                          Height="30"
                          Margin="0,10,0,0"
                            VerticalAlignment="Center"
                      />

                        <TextBlock
                               Grid.Column="1"
                          x:Name="SchichtStandorte"
                            Height="30"
                          Text="Dokuzentrum"
                          Foreground="White"
                          FontSize="16"
                          Margin="0,10,0,0"
                          Visibility="Collapsed"
                          />

                        <ListBox 
                            Grid.Column="1"
                            x:Name="Locations"
                            Height="30"
                            SelectionMode="Multiple"
                            Visibility="Visible"
                            Background="Transparent"
                            BorderBrush="LightGray"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom">
                            


                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="#2D2D30"/>
                                    <Setter Property="Margin" Value="5"/>
                                    <Setter Property="VerticalAlignment"  Value="Bottom"/>
                                </Style>
                            </ListBox.ItemContainerStyle>

                        </ListBox>

                    </Grid>
                <Grid Margin="0,10,0,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <TextBlock
                       Grid.Column="0"
                         Text="Rollen:"
                         Foreground="White"
                        Height="30"
                         FontSize="16"
                         />

                    <TextBlock
                       Grid.Column="1"
                     x:Name="RText"
                     Text="Hans"
                        Height="30"
                     Foreground="White"
                     FontSize="16"
                       Visibility="Visible"
          
                     />

                    <ListBox 
                      Grid.Column="1"
                      x:Name="RoleSelection"
                      SelectionMode="Multiple"
                      Visibility="Collapsed"
                        Height="30"
                      Background="Transparent"
                      BorderBrush="LightGray"
                      HorizontalAlignment="Left">


                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#2D2D30"/>
                                <Setter Property="Margin" Value="5"/>
                                <Setter Property="VerticalAlignment"  Value="Center"/>
                            </Style>
                        </ListBox.ItemContainerStyle>

                    </ListBox>
                </Grid>

    
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="100"/>
                        <ColumnDefinition  Width="150"/>
                        <ColumnDefinition  Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock
                         Grid.Column="0"
                         Text="Ziel-Stunden: "
                         Foreground="White"
                        Height="30"
                         FontSize="16"
                         />
                    <TextBlock
                    Grid.Column="1"
                    x:Name="ZielStundenText"
                    Text="160"
                        Height="30"
                    Foreground="White"
                    FontSize="16"
                        Visibility="Visible"
                    />
                    
                    <TextBox
                       Grid.Column="1"
                       x:Name="ZielStundenBox"
                       Text="160"
                        Height="30"
                       FontSize="16"
                        CaretBrush="White"
                       Margin="0,0,50,0"
                       Foreground="White"
                     BorderBrush="LightGray"
                     Visibility="Collapsed"
                        HorizontalAlignment="Left"
                      Background="Transparent"
                       >
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Grid.Column="2"
                  x:Name="PlannedStundenText"
                               Height="30"
                  Text="Verplantestunden: "
                  Foreground="White"
                  FontSize="16"
                  />

                </Grid>

                

            </StackPanel>
            
            
            
            
            <TextBlock
              Text="Arbeitstage: "
              Foreground="White"
              FontSize="20"
                FontWeight="Bold"
                Margin="0,15,0,0"
              />
            <StackPanel Margin="10,0,0,0">
           

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="110"/>
                        <ColumnDefinition  Width="auto"/>
                        <ColumnDefinition  Width="auto" MinWidth="35"/>
                        <ColumnDefinition  Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                            Grid.Column="0"
                            Text="Abwesend: "
                            Foreground="White"
                            FontSize="16"
                     />

                    <TextBlock
                       Grid.Column="1"
                       x:Name="AbwesendeTage"
                       Text=""
                       Foreground="White"
                       FontSize="16"
                       Visibility="Visible"
                     />
                    
                    
                    
                    <TextBox
                          Grid.Column="1"
                          x:Name="abwesendBox"
                          Text="Sa,So,10-14,31"
                          FontSize="16"
                           MinWidth="50"
                           CaretBrush="White"
                          Margin="0,0,50,0"
                          Foreground="White"
                        BorderBrush="LightGray"
                        Visibility="Collapsed"
                           HorizontalAlignment="Left"
                         Background="Transparent"
                       >
                        <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="LightGray"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        </TextBox.Style>
                    </TextBox>

                    <CheckBox
                      Grid.Column="2"
                      x:Name="CarryOverAbwesenheiten"
                      Foreground="White"
                      FontSize="16"
                      HorizontalAlignment="Center"
                      IsHitTestVisible="False"
                      />

                    <Border Width="18" Grid.Column="3" x:Name="AbwesenheitsTooltip"
                           Height="18"
                           CornerRadius="9" HorizontalAlignment="Left"
                           Background="#3A3A3A" Margin="5,0,0,0"
                           Visibility="Collapsed"
                           Cursor="Help" VerticalAlignment="Center">
                        <Border.ToolTip>
                            <ToolTip FontSize="16">
                                <TextBlock TextWrapping="Wrap">
                                    Wochentage:     Mo,Di,Mi...
                                    <LineBreak/>
                                    Einzeltage:     1,10,15,20...
                                    <LineBreak/>
                                    Zeitspannen:    5-15,18-21...
                                    <LineBreak/>
                                    Beschreibung:   5(Urlaub) oder 5(Urlaub(UR))
                                </TextBlock>
                            </ToolTip>
                        </Border.ToolTip>
                        
                        <TextBlock Text="i"
                          Foreground="Yellow"
                          FontWeight="Bold"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                    </Border>
                    
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="110"/>
                        <ColumnDefinition  Width="auto" MinWidth="140"/>
                        <ColumnDefinition  Width="auto" MinWidth="35"/>
                        <ColumnDefinition  Width="110"/>
                        <ColumnDefinition  Width="auto"/>
                        <ColumnDefinition  Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                     Grid.Column="0"
                     Text="Einsatzwunsch: "
                     Foreground="White"
                     FontSize="16"
                    />

                    <TextBlock
                        Grid.Column="1"
                        x:Name="EinsatzTage"
                        Text=""
                        Foreground="White"
                        FontSize="16"
                        Visibility="Visible"
                      />

                    <TextBox
                       Grid.Column="1"
                       x:Name="EinsatzBox"
                       Text="Sa,So,10-14,31"
                       FontSize="16"
                        MinWidth="50"
                        CaretBrush="White"
                       Margin="0,0,50,0"
                       Foreground="White"
                     BorderBrush="LightGray"
                     Visibility="Collapsed"
                        HorizontalAlignment="Left"
                      Background="Transparent"
            >
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <CheckBox
                        Grid.Column="2"
                        x:Name="CarryOverEinsaetze"
                        Foreground="White"
                        FontSize="16"
                        HorizontalAlignment="Center"
                        IsHitTestVisible="False"
                        />
                    
                    <TextBlock
                         Grid.Column="3"
                         Text="Freizeitwunsch: "
                         Foreground="White"
                         FontSize="16"
                        />

                    <TextBlock
                        Grid.Column="4"
                        x:Name="FreizeitTage"
                        Text=""
                        Foreground="White"
                        FontSize="16"
                        Visibility="Visible"
                      />
                       

                    <TextBox
                       Grid.Column="4"
                       x:Name="FreizeitBox"
                       Text="Sa,So,10-14,31"
                       FontSize="16"
                        MinWidth="50"
                        CaretBrush="White"
                       Margin="0,0,50,0"
                       Foreground="White"
                     BorderBrush="LightGray"
                     Visibility="Collapsed"
                        HorizontalAlignment="Left"
                      Background="Transparent"
>
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <CheckBox
                       Grid.Column="5"
                       x:Name="CarryOverFreizeit"
                       Foreground="White"
                         HorizontalAlignment="Center"
                       FontSize="16"
                       IsHitTestVisible="False"
                       />
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition  Width="300"/>
                        <ColumnDefinition  Width="auto"/>
                        <ColumnDefinition  Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                           Grid.Column="0"
                           Text="Max. aufeinanderfolgende Arbeitstage:"
                           Foreground="White"
                           FontSize="16"
                    />

                    <TextBlock
                          Grid.Column="1"
                          x:Name="TageAmStueck"
                          Text="5"
                          Foreground="White"
                          FontSize="16"
                          Visibility="Visible"
                        />

                    <TextBox
                         Grid.Column="1"
                         x:Name="TageAmStueckBox"
                         Text="Sa,So,10-14,31"
                         FontSize="16"
                          MinWidth="50"
                          CaretBrush="White"
                         Margin="0,0,50,0"
                         Foreground="White"
                       BorderBrush="LightGray"
                       Visibility="Collapsed"
                          HorizontalAlignment="Left"
                        Background="Transparent"
                      >
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                </Grid>



            </StackPanel>
            <TextBlock
                  Text="Schichten: "
                  Foreground="White"
                  FontSize="20"
                FontWeight="Bold"
                Margin="0,15,0,0"
                  />
            
            <Grid Margin="10,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition  Width="70"/>
                    <ColumnDefinition  Width="30"/>
                    <ColumnDefinition  Width="20"/>
                    <ColumnDefinition  Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock
                      Grid.Column="0"
                      Text="Anzahl: "
                      Foreground="White"
                      FontSize="16"
                      />
                <TextBlock
                     Grid.Column="1"
                     x:Name="SchichtZahl"
                     Text="8"
                     Foreground="White"
                    HorizontalAlignment="Right"
                     FontSize="16"
                         Visibility="Visible"
                     />

                <TextBlock
                    Grid.Column="2"
                    Text="|" 
 
                    Foreground="White"
                    FontSize="20"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                        Visibility="Visible" Margin="0,-5,0,0"
                    />

                <TextBlock
                    Grid.Column="3"
                    x:Name="SchichtAls"
                    Margin="0,0,0,0"
                    Text="160"
                    Foreground="White"
                    FontSize="16"
                    />

         

            </Grid>

            <ScrollViewer Margin="10,10,0,0" HorizontalAlignment="Left" VerticalScrollBarVisibility="Auto" MaxHeight="300">

                <WrapPanel x:Name="RolePanel"
               Orientation="Horizontal"/>
             
               
            </ScrollViewer>

           

        </StackPanel>

    </Border>
</Window>
