<UserControl x:Class="ShiftPlanner.Subwidgets.DailyShiftsHandle"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>


        <Style x:Key="ArrowlessComboBoxStyle"
       TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="LightGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="50"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            MinWidth="{TemplateBinding MinWidth}"
                            Height="30"
                                    VerticalAlignment="Top"
                            CornerRadius="0">

                                <Grid>
                                    <!-- Selected value -->
                                    <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                                    <!-- Invisible clickable area -->
                                    <ToggleButton
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen,
                                                   RelativeSource={RelativeSource TemplatedParent},
                                                   Mode=TwoWay}"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False"
                           IsOpen="{TemplateBinding IsDropDownOpen}"
                           PopupAnimation="Fade">

                                <Border Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                MinWidth="{Binding ActualWidth,
                                                   RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border"
                                Property="BorderBrush"
                                Value="#777777"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border"
                                Property="Opacity"
                                Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    
    <Border x:Name="RootBorder"
        Background="#3A3A3A"
        CornerRadius="6"
        BorderThickness="2"
        Padding="5"
        Margin="0,0,0,8">
        <StackPanel Orientation="Horizontal">
            <Grid Margin="0,10,0,0" Name="RoleGrid">

            <Grid.ColumnDefinitions>
                    <ColumnDefinition MinWidth="50" Width="auto"/>
                </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
            </Grid.RowDefinitions>

            <TextBlock
        Grid.Column="0"
          Text="Rolle:"
          Foreground="White"
          HorizontalAlignment="Center"
         Height="30"
          FontSize="16"
          />

            <TextBlock
                Grid.Column="0"
                Grid.Row="1"
              x:Name="RText"
              Text="Hans"
                 Height="30"
              Foreground="White"
              FontSize="16"
                HorizontalAlignment="Center"
                Visibility="Hidden"
          
                />

            <ComboBox 
               Grid.Column="1"
               Grid.Row="1"
               x:Name="RoleSelection"
               Visibility="Visible"
               HorizontalAlignment="Left" Style="{StaticResource ArrowlessComboBoxStyle}">


                <ComboBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ComboBox.ItemsPanel>

             

            </ComboBox>
        </Grid>

            <Grid Margin="10,10,0,0" Name="AnzahlGrid">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="55"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <TextBlock
                  Grid.Column="0"
                    Text="Anzahl:"
                    Foreground="White"
                    HorizontalAlignment="Center"
                   Height="30"
                    FontSize="16"
                    />

                <TextBlock
                      Grid.Column="0"
                      Grid.Row="1"
                    x:Name="Anzahl"
                    Text="Hans"
                       Height="30"
                    HorizontalAlignment="Center"
                    Foreground="White"
                    FontSize="16"
                      Visibility="Hidden"
    
                    />
                <TextBox
                    Grid.Column="0"
                     Grid.Row="1"
                    x:Name="AnzahlBox"
                    Text="1"
                    FontSize="16"
                     MinWidth="50"
                    Height="30"
                    VerticalContentAlignment="Center"
                  VerticalAlignment="Top"
                     CaretBrush="White"
                    Foreground="White"
                  BorderBrush="LightGray"
                  Visibility="Visible"
                    HorizontalContentAlignment="Center"
                   Background="Transparent">

                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="LightGray"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>

            <Grid Margin="10,10,0,0" Name="SchichtGrid">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"></RowDefinition>
                    <RowDefinition Height="auto"></RowDefinition>
                </Grid.RowDefinitions>
                
                <TextBlock Text="Schichtdauer:"
                   FontSize="16"
                   Foreground="White" HorizontalAlignment="Center"
                 Grid.Column="0" Grid.Row="0"/>


                <Grid Margin="0,0,0,0" Grid.Row="1">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                         x:Name="Begin_Box"
                         Text="08:00"
                         FontSize="16"
                         Width="50"
                             Height="30"
                             CaretBrush="White"
                         Background="Transparent"
                             VerticalContentAlignment="Center"
                         Foreground="White">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <TextBlock Grid.Column="1"
                          Text="-"
                          FontSize="16"
                          Foreground="White"
                          Margin="0,0,0,0"
                          HorizontalAlignment="Center"/>


                    <TextBox Grid.Column="2"
                         x:Name="Ende_Box"
                         Text="16:30"
                         FontSize="16"
                         Width="50"
                             CaretBrush="White"
                             VerticalContentAlignment="Center"
                         Background="Transparent"
                         Foreground="White">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="LightGray"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                </Grid>
            </Grid>

            <Grid Margin="10,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition  Width="auto"/>
                    <ColumnDefinition  Width="50"/>
        
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition  Height="30"/>
                    <RowDefinition  Height="auto"/>
                </Grid.RowDefinitions>
                <TextBlock
                         Grid.Column="0"
                         Text="Tage: "
                    HorizontalAlignment="Center"
                         Foreground="White"
                         FontSize="16"
                     />

                <TextBlock
                    Grid.Column="0"
                    Grid.Row="1"
                    x:Name="Tage"
                    Text=""
                    Foreground="White"
                    FontSize="16"
                    Visibility="Collapsed"
                  />

                <TextBox
                       Grid.Column="0"
                        Grid.Row="1"
                       x:Name="Tagesbox"
                       Text=""
                    Height="30"
                       FontSize="16"
                        MinWidth="50"
                        CaretBrush="White"
                       Foreground="White"
                     BorderBrush="LightGray"
                     Visibility="Visible"
                    VerticalContentAlignment="Center"
                        HorizontalAlignment="Center"
                      Background="Transparent"
                    >
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="BorderBrush" Value="LightGray"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <Border Width="18" Grid.Column="2" x:Name="Tooltip"
                        Height="18"
                        CornerRadius="9" HorizontalAlignment="Left"
                        Background="#3A3A3A" Margin="5,0,0,0"
                        Visibility="Visible"
                        Cursor="Help" VerticalAlignment="Center">
                    <Border.ToolTip>
                        <ToolTip FontSize="16">
                            <TextBlock TextWrapping="Wrap">
                     Wochentage:     Mo,Di,Mi...
                     <LineBreak/>
                     Einzeltage:     1,10,15,20...
                     <LineBreak/>
                     Zeitspannen:    5-15,18-21...
                            </TextBlock>
                        </ToolTip>
                    </Border.ToolTip>

                    <TextBlock Text="i"
                       Foreground="Yellow"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
                </Border>

            </Grid>
        </StackPanel>
        
    </Border>
</UserControl>
