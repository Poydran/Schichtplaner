<UserControl x:Class="ShiftPlanner.Subwidgets.PlanStandort"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShiftPlanner.Subwidgets"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="230">
    <Border x:Name="RootBorder"
            Background="#3A3A3A"
            CornerRadius="6"
            Padding="5"
            Margin="0,0,0,8"
            MouseLeftButtonDown="RootBorder_MouseLeftButtonDown"
            MouseRightButtonDown="RootBorder_MouseRightButtonDown"
            >

        <StackPanel>
            <TextBlock x:Name="NameText"
                       Text="Standort"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="Bold"/>


            <TextBlock 
                Text="Rechtsklick zum bearbeiten"
                Foreground="DarkGray"
                FontSize="12"
                Margin="5,5,0,0"/>

        </StackPanel>

    </Border>
</UserControl>
